    {
      "name": "3. Validate Raffle",
      "description": "STEP 3 — Raffle station scans the client's QR. Decrypts and validates it, then creates the raffle entry. Participant record and scan logs were already created at generate-raffle-qr time. Returns raffleEntryId used for the spin.",
      "item": [
        {
          "name": "Validate Raffle QR ✓",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Participant + entry created', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data.raffleEntryId).to.be.a('number');",
                  "  pm.expect(json.data.participantId).to.be.a('number');",
                  "  pm.collectionVariables.set('raffleEntryId', String(json.data.raffleEntryId));",
                  "  pm.collectionVariables.set('participantId', String(json.data.participantId));",
                  "  console.log('participantId:', json.data.participantId);",
                  "  console.log('participantCode:', json.data.participantCode);",
                  "  console.log('raffleEntryId:', json.data.raffleEntryId);",
                  "  console.log('totalPoints:', json.data.totalPoints);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"encryptedQr\": \"{{encryptedQr}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaignId}}/validate-raffle",
              "host": ["{{base_url}}"],
              "path": ["campaigns", "{{campaignId}}", "validate-raffle"]
            },
            "description": "Uses encryptedQr saved from Step 2. Creates participant + scan logs + raffle entry in one transaction. raffleEntryId and participantId are auto-saved."
          },
          "response": [
            {
              "name": "200 - Validated",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Raffle QR validated. Participant is eligible to spin.\",\n  \"data\": {\n    \"raffleEntryId\": 1,\n    \"participantId\": 1,\n    \"participantCode\": \"CLIENT-DEVICE-ABC123\",\n    \"fullName\": \"Juan dela Cruz\",\n    \"campaignId\": 1,\n    \"totalPoints\": 350,\n    \"thresholdPoints\": 300,\n    \"status\": \"pending\",\n    \"dateCreated\": \"2026-04-01T08:05:00.000Z\"\n  }\n}"
            },
            {
              "name": "409 - QR Already Used",
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Raffle QR has already been used\"\n}"
            },
            {
              "name": "409 - Duplicate Participant",
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"This participant has already joined this campaign\"\n}"
            }
          ]
        },
