    {
      "name": "1. Get Campaign by Event Tag",
      "description": "STEP 1 — Client entry point. Returns active campaign details and active booth list. Client uses the booth list to display scannable QR codes. campaignId is auto-saved for subsequent requests.",
      "item": [
        {
          "name": "Get Campaign by Event Tag",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns campaign + booth list', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data.campaign).to.be.an('object');",
                  "  pm.expect(json.data.booths).to.be.an('array');",
                  "  pm.collectionVariables.set('campaignId', String(json.data.campaign.id));",
                  "  console.log('Campaign ID saved:', json.data.campaign.id);",
                  "  console.log('Active booths:', json.data.booths.length);",
                  "  console.log('Total booth points available:', json.data.totalBoothPoints);",
                  "  console.log('Threshold:', json.data.thresholdPoints);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/campaigns/event/{{eventTag}}",
              "host": ["{{base_url}}"],
              "path": ["campaigns", "event", "{{eventTag}}"]
            }
          },
          "response": [
            {
              "name": "200 - Campaign + Booths",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Campaign retrieved\",\n  \"data\": {\n    \"campaign\": {\n      \"id\": 1,\n      \"campaignCode\": \"RFFL-2026-001\",\n      \"campaignName\": \"Worldbex 2026 Raffle Campaign\",\n      \"eventTag\": \"WORLDBEX2026\",\n      \"description\": \"Collect points from all booths and join the grand raffle draw.\",\n      \"thresholdPoints\": 300,\n      \"startDate\": \"2026-04-01T00:00:00.000Z\",\n      \"endDate\": \"2026-04-05T23:59:59.000Z\",\n      \"status\": \"active\"\n    },\n    \"booths\": [\n      { \"id\": 20260001, \"boothCode\": \"BOOTH-MAIN-01\", \"boothName\": \"Main Stage\",     \"points\": 100, \"maxScanPerUser\": 1, \"sortOrder\": 1 },\n      { \"id\": 20260002, \"boothCode\": \"BOOTH-TECH-01\", \"boothName\": \"Tech Zone\",      \"points\": 75,  \"maxScanPerUser\": 1, \"sortOrder\": 2 },\n      { \"id\": 20260003, \"boothCode\": \"BOOTH-FOOD-01\", \"boothName\": \"Food Court\",     \"points\": 50,  \"maxScanPerUser\": 1, \"sortOrder\": 3 },\n      { \"id\": 20260004, \"boothCode\": \"BOOTH-INNO-01\", \"boothName\": \"Innovation Hub\", \"points\": 75,  \"maxScanPerUser\": 1, \"sortOrder\": 4 },\n      { \"id\": 20260005, \"boothCode\": \"BOOTH-SPON-01\", \"boothName\": \"Sponsors Area\",  \"points\": 50,  \"maxScanPerUser\": 1, \"sortOrder\": 5 }\n    ],\n    \"thresholdPoints\": 300,\n    \"totalBoothPoints\": 350\n  }\n}"
            },
            {
              "name": "400 - Campaign Not Active",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Campaign is not active\"\n}"
