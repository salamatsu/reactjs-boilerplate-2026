    {
      "name": "4. Spin Wheel",
      "description": "STEP 4 — The wheel spins client-side. The client sends the outcome to the server. Server records the result, creates a claim on win, and marks the raffle entry accordingly.\n\nSend `prizeName: 'No Prize'` for a losing spin.",
      "item": [
        {
          "name": "Spin Wheel — Win Prize ✓",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Prize awarded', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data.outcome).to.equal('won');",
                  "  pm.expect(json.data.prize).to.not.be.null;",
                  "  console.log('claimId:', json.data.prize.claimId);",
                  "  console.log('prizeName:', json.data.prize.prizeName);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"raffleEntryId\": \"{{raffleEntryId}}\",\n  \"prizeName\": \"Samsung 65-inch Smart TV\",\n  \"wheelResult\": \"Samsung 65-inch Smart TV\",\n  \"claimedBy\": \"Event Staff - Maria\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaignId}}/spin-wheel",
              "host": ["{{base_url}}"],
              "path": ["campaigns", "{{campaignId}}", "spin-wheel"]
            },
            "description": "Wheel landed on a prize. Server creates a campaign_claims record and marks entry as 'won'."
          },
          "response": [
            {
              "name": "200 - Win",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Congratulations! Prize awarded.\",\n  \"data\": {\n    \"raffleEntryId\": \"1\",\n    \"participantId\": 1,\n    \"outcome\": \"won\",\n    \"wheelResult\": \"Samsung 65-inch Smart TV\",\n    \"prize\": {\n      \"claimId\": 1,\n      \"prizeName\": \"Samsung 65-inch Smart TV\",\n      \"claimedBy\": \"Event Staff - Maria\",\n      \"claimedAt\": \"2026-04-01T08:10:00.000Z\",\n      \"status\": \"won\"\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Spin Wheel — No Prize ✓",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('No prize outcome', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data.outcome).to.equal('lost');",
                  "  pm.expect(json.data.prize).to.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"raffleEntryId\": \"{{raffleEntryId}}\",\n  \"prizeName\": \"No Prize\",\n  \"wheelResult\": \"No Prize\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaignId}}/spin-wheel",
              "host": ["{{base_url}}"],
              "path": ["campaigns", "{{campaignId}}", "spin-wheel"]
            },
            "description": "Wheel landed on 'No Prize'. No claim record is created. Entry marked as 'lost'."
          },
          "response": [
            {
              "name": "200 - No Prize",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Better luck next time.\",\n  \"data\": {\n    \"raffleEntryId\": \"1\",\n    \"participantId\": 1,\n    \"outcome\": \"lost\",\n    \"wheelResult\": \"No Prize\",\n    \"prize\": null\n  }\n}"
            }
          ]
        },
        {
          "name": "Spin Wheel — Already Processed ✗",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 409', () => pm.response.to.have.status(409));",
                  "pm.test('Already processed error', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.false;",
                  "  pm.expect(json.message).to.include('already been processed');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"raffleEntryId\": \"{{raffleEntryId}}\",\n  \"prizeName\": \"iPhone 16 Pro\",\n  \"wheelResult\": \"iPhone 16 Pro\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaignId}}/spin-wheel",
              "host": ["{{base_url}}"],
              "path": ["campaigns", "{{campaignId}}", "spin-wheel"]
            },
            "description": "Re-spin the same entry after it has been processed."
          },
          "response": []
        }
      ]
    },
